<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>RubySage — Artifact Browser</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, -apple-system, "Segoe UI", sans-serif; background: #f5f5f5; color: #111; }
    .rs-admin-header { background: #1a1a1a; color: #fff; padding: 16px 24px; display: flex; align-items: center; gap: 12px; }
    .rs-admin-header h1 { font-size: 18px; font-weight: 600; }
    .rs-admin-header a { color: #aaa; text-decoration: none; font-size: 13px; }
    .rs-admin-header a:hover { color: #fff; }
    .rs-admin-body { max-width: 960px; margin: 32px auto; padding: 0 16px; }
    .rs-filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; align-items: center; }
    .rs-filter-btn { padding: 5px 14px; border-radius: 20px; border: 1px solid #ddd; background: #fff; font-size: 13px; cursor: pointer; text-decoration: none; color: #333; }
    .rs-filter-btn:hover { background: #f0f0f0; }
    .rs-filter-btn.rs-active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
    .rs-artifact { background: #fff; border: 1px solid #e5e5e5; border-radius: 8px; padding: 16px; margin-bottom: 12px; }
    .rs-artifact-path { font-family: monospace; font-size: 13px; color: #1a1a1a; font-weight: 600; }
    .rs-artifact-kind { display: inline-block; font-size: 11px; background: #f1f5f9; color: #475569; padding: 2px 8px; border-radius: 12px; margin-left: 8px; vertical-align: middle; }
    .rs-artifact-symbols { font-size: 12px; color: #888; margin-top: 6px; font-family: monospace; }
    .rs-artifact-summary { font-size: 14px; color: #444; margin-top: 8px; line-height: 1.5; }
    .rs-empty { text-align: center; color: #888; padding: 48px; font-size: 14px; }
    .rs-pagination { display: flex; gap: 8px; justify-content: center; margin-top: 24px; }
    .rs-pagination a, .rs-pagination span { padding: 6px 14px; border: 1px solid #ddd; border-radius: 6px; font-size: 13px; text-decoration: none; color: #333; }
    .rs-pagination .rs-current { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
    .rs-count { font-size: 13px; color: #888; }
  </style>
</head>
<body>

<header class="rs-admin-header">
  <h1>RubySage</h1>
  <span style="color:#666;font-size:13px;">/</span>
  <%= link_to "Scans", ruby_sage.admin_scans_path %>
  <span style="color:#666;font-size:13px;">/</span>
  <span style="color:#fff;font-size:13px;">Artifact Browser</span>
</header>

<div class="rs-admin-body">

  <% if @scan.nil? %>
    <p class="rs-empty">No completed scan found. Run <code>bundle exec rake ruby_sage:scan</code> first.</p>
  <% else %>

    <div class="rs-filter-bar">
      <%= link_to "All", ruby_sage.admin_artifacts_path,
            class: "rs-filter-btn#{@current_kind.nil? ? ' rs-active' : ''}" %>
      <% @kinds.each do |kind| %>
        <%= link_to kind.capitalize, ruby_sage.admin_artifacts_path(kind: kind),
              class: "rs-filter-btn#{@current_kind == kind ? ' rs-active' : ''}" %>
      <% end %>
      <span class="rs-count"><%= @total %> file<%= @total == 1 ? '' : 's' %></span>
    </div>

    <% if @artifacts.empty? %>
      <p class="rs-empty">No artifacts found<%= @current_kind ? " for kind \"#{@current_kind}\"" : "" %>.</p>
    <% else %>
      <% @artifacts.each do |artifact| %>
        <div class="rs-artifact">
          <div>
            <span class="rs-artifact-path"><%= artifact.path %></span>
            <span class="rs-artifact-kind"><%= artifact.kind || "other" %></span>
          </div>
          <% if Array(artifact.public_symbols).any? %>
            <div class="rs-artifact-symbols"><%= Array(artifact.public_symbols).join(" · ") %></div>
          <% end %>
          <% if artifact.summary.present? %>
            <div class="rs-artifact-summary"><%= artifact.summary %></div>
          <% end %>
        </div>
      <% end %>

      <% if @total_pages > 1 %>
        <div class="rs-pagination">
          <% if @page > 1 %>
            <%= link_to "← Prev", ruby_sage.admin_artifacts_path(kind: @current_kind, page: @page - 1) %>
          <% end %>
          <span class="rs-current">Page <%= @page %> of <%= @total_pages %></span>
          <% if @page < @total_pages %>
            <%= link_to "Next →", ruby_sage.admin_artifacts_path(kind: @current_kind, page: @page + 1) %>
          <% end %>
        </div>
      <% end %>
    <% end %>

  <% end %>
</div>
</body>
</html>
